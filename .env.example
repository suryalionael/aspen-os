# Supabase project credentials — obtain from your Supabase project settings (Settings > API).
# Copy this file to .env.local and fill in real values. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role (secret) key — Project Settings > API > "service_role" secret.
# Server-only: deliberately NOT prefixed with NEXT_PUBLIC_, so Next.js never
# bundles it into client code. Used by lib/supabase/admin.ts exclusively for
# self-account-deletion (lib/actions/account.ts) — never import that file
# from a Client Component or any browser-reachable code path.
SUPABASE_SERVICE_ROLE_KEY=
